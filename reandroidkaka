                  display: "flex", alignItems: "center", gap: 5, padding: "7px 12px",
                  borderRadius: 18, border: "none", cursor: "pointer", fontSize: 12, fontWeight: 700,
                  background: active ? P.ink : P.paper, color: active ? P.paper : P.ink2,
                  boxShadow: active ? "none" : `inset 0 0 0 1px ${P.line}`,
