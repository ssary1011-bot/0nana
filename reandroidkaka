/* =========================================================================
   2) 재사용 컴포넌트
   ========================================================================= */

function HexText({ value, onCommit }) {
  const [text, setText] = useState(value);
  useEffect(() => setText(value), [value]);
  const commit = () => {
    const v = text.trim();
    if (/^#?[0-9a-fA-F]{6}$/.test(v)) onCommit(v.startsWith("#") ? v : "#" + v);
    else setText(value);
  };
  return (
    <input
      value={text}
      onChange={(e) => setText(e.target.value)}
      onBlur={commit}
      onKeyDown={(e) => e.key === "Enter" && commit()}
      style={{
        width: 62, fontSize: 10, color: P.ink3, fontFamily: "monospace",
        border: "none", background: "transparent", outline: "none",
      }}
    />
  );
}

/** 색상 항목 한 줄: 스와치 + 라벨 + hex텍스트 + (옵션)투명도 슬라이더 + 네이티브 컬러피커
 *  -- 예전엔 이 한 줄이 7줄짜리 HTML(.color-item)로 80곳 가까이 중복돼 있었음 */
function ColorItem({ field, value, alpha, onColor, onAlpha }) {
  return (
    <div
      style={{
        display: "flex", alignItems: "center", gap: 8, padding: "8px 10px",
        background: P.paper, border: `1px solid ${P.line}`, borderRadius: 10,
      }}
    >
      <label
        style={{
          width: 22, height: 22, borderRadius: "50%", border: `2px solid ${P.line2}`,
          background: value, flexShrink: 0, cursor: "pointer", position: "relative",
        }}
      >
        <input
          type="color"
          value={value}
          onChange={(e) => onColor(e.target.value)}
          style={{ opacity: 0, width: "100%", height: "100%", cursor: "pointer" }}
        />
      </label>
      <span style={{ fontSize: 12, fontWeight: 700, color: P.ink, flex: 1 }}>{field.label}</span>
      <HexText value={value} onCommit={onColor} />
      {field.alpha && (
        <input
          type="range" min={0} max={100} value={alpha}
          onChange={(e) => onAlpha(Number(e.target.value))}
          title="투명도"
          style={{ width: 50, accentColor: P.accent }}
        />
      )}
    </div>
  );
}

/** 색상 그룹: 제목 + ColorItem 목록 (필드 배열만 바꾸면 어떤 그룹이든 생성됨) */
function ColorGroup({ title, fields, colors, alphas, onColor, onAlpha }) {
  return (
    <div style={{ marginBottom: 18 }}>
      <div
        style={{
          fontSize: 11, fontWeight: 800, color: P.accent2, marginBottom: 8,
          borderLeft: `3px solid ${P.accent}`, paddingLeft: 8,
        }}
      >
        {title}
      </div>
      <div style={{ display: "grid", gridTemplateColumns: "repeat(2, 1fr)", gap: 8 }}>
        {fields.map((f) => (
          <ColorItem
            key={f.id}
            field={f}
            value={colors[f.id] ?? f.def}
            alpha={alphas[f.id] ?? 100}
            onColor={(v) => onColor(f.id, v)}
            onAlpha={(v) => onAlpha(f.id, v)}
          />
        ))}
      </div>
    </div>
  );
}

/** 이미지 업로드 슬롯 하나
 *  -- 예전엔 .img-slot 마크업(라벨+썸네일+사이즈+뱃지+x버튼)이 30곳 넘게 중복돼 있었음 */
function ImageSlot({ field, image, onUpload, onClear }) {
  const inputRef = useRef(null);
  return (
    <div
      style={{
        display: "flex", alignItems: "center", gap: 10, padding: "8px 10px",
        background: P.paper, border: `1px solid ${P.line}`, borderRadius: 10, position: "relative",
      }}
    >
      <button
        onClick={() => inputRef.current?.click()}
        style={{
          width: 40, height: 40, borderRadius: 8, background: P.bg, border: `1px solid ${P.line}`,
          display: "flex", alignItems: "center", justifyContent: "center", overflow: "hidden",
          flexShrink: 0, cursor: "pointer",
        }}
        title="클릭해서 업로드"
      >
        {image ? (
          <img src={image.url} alt="" style={{ width: "100%", height: "100%", objectFit: "cover" }} />
        ) : (
          <ImageIcon size={16} color={P.ink3} />
        )}
      </button>
      <input
        ref={inputRef} type="file" accept="image/*" style={{ display: "none" }}
        onChange={(e) => e.target.files?.[0] && onUpload(e.target.files[0])}
      />
      <div style={{ flex: 1, minWidth: 0 }}>
        <div style={{ fontSize: 12, fontWeight: 700, color: P.ink }}>{field.label}</div>
        <div style={{ fontSize: 10, color: P.ink3 }}>{field.size}</div>
      </div>
      <span
        style={{
          fontSize: 9, fontWeight: 700, padding: "2px 7px", borderRadius: 7,
          background: image ? P.accentSoft : P.bg, color: image ? P.accent2 : P.ink3, flexShrink: 0,
        }}
      >
        {image ? "업로드됨" : field.badge}
      </span>
      {image && (
        <button
          onClick={onClear}
          style={{
            width: 18, height: 18, borderRadius: "50%", border: "none", background: P.line,
            display: "flex", alignItems: "center", justifyContent: "center", cursor: "pointer", flexShrink: 0,
          }}
        >
          <X size={11} color={P.ink} />
        </button>
      )}
    </div>
  );
}

/** 이미지 섹션: 제목 + ImageSlot 그리드 */
function ImgSection({ title, slots, images, onUpload, onClear }) {
  return (
    <div style={{ marginBottom: 16 }}>
      <div style={{ fontSize: 11, fontWeight: 800, color: P.accent2, marginBottom: 8 }}>{title}</div>
      <div style={{ display: "grid", gridTemplateColumns: "repeat(2, 1fr)", gap: 8 }}>
        {slots.map((s) => (
          <ImageSlot
            key={s.id}
            field={s}
            image={images[s.id]}
            onUpload={(file) => onUpload(s.id, file)}
            onClear={() => onClear(s.id)}
          />
        ))}
      </div>
    </div>
  );
}

