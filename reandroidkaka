            )}

            {colorGroups.length > 0 && (
              <div style={{ marginBottom: 24 }}>
                <div style={{ fontSize: 13, fontWeight: 800, marginBottom: 12 }}>🎨 색상 편집</div>
                {colorGroups.map((g) => (
                  <ColorGroup key={g.title} {...g} colors={colors} alphas={alphas} onColor={setColor} onAlpha={setAlpha} />
                ))}
              </div>
            )}

            {imageGroups.length > 0 && (
              <div>
                <div style={{ fontSize: 13, fontWeight: 800, marginBottom: 12 }}>🖼 이미지 리소스</div>
                {imageGroups.map((g) => (
                  <ImgSection key={g.title} {...g} images={images} onUpload={upload} onClear={clear} />
                ))}
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  );
}
