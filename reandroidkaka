        <p style={{ fontSize: 12, color: P.ink2, marginBottom: 20 }}>
          색상 항목 {totalFields}개 + 이미지 슬롯 {totalSlots}개를 전부{" "}
          <code style={{ background: P.line, padding: "1px 5px", borderRadius: 4 }}>&lt;ColorItem /&gt;</code> /{" "}
          <code style={{ background: P.line, padding: "1px 5px", borderRadius: 4 }}>&lt;ImageSlot /&gt;</code> 두 컴포넌트 하나로 렌더링합니다.
        </p>

        {/* 탭 */}
        <div style={{ display: "flex", gap: 6, flexWrap: "wrap", marginBottom: 20 }}>
          {TABS.map((t) => {
            const Icon = t.icon;
            const active = tab === t.key;
            return (
              <button
