  const [alphas, setAlphas] = useState({});
  const [images, setImages] = useState({});

  const setColor = (id, v) => setColors((p) => ({ ...p, [id]: v }));
  const setAlpha = (id, v) => setAlphas((p) => ({ ...p, [id]: v }));
  const upload = (id, file) => setImages((p) => ({ ...p, [id]: { url: URL.createObjectURL(file), name: file.name } }));
  const clear = (id) => setImages((p) => { const n = { ...p }; delete n[id]; return n; });

  const colorGroups = COLOR_GROUPS[tab] || [];
  const imageGroups = IMAGE_GROUPS[tab] || [];
  const totalFields = Object.values(COLOR_GROUPS).flat().reduce((a, g) => a + g.fields.length, 0);
  const totalSlots = Object.values(IMAGE_GROUPS).flat().reduce((a, g) => a + g.slots.length, 0);

  return (
    <div style={{ background: P.bg, minHeight: "100vh", fontFamily: "'Noto Sans KR', sans-serif", color: P.ink }}>
      <div style={{ maxWidth: 1100, margin: "0 auto", padding: "24px 16px" }}>
